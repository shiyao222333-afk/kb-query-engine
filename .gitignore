# Citrinitas 知识库引擎
# ============

# Python 虚拟环境
venv/

# 本地数据（图片、索引、报告、死信）
local_data/
qdrant_data/
snapshots/
storage/

# Qdrant 本地安装目录（由 run.bat 自动下载）
qdrant/

# 运行时锁文件
data/.watch_v2.lock
data/.watch_v2_migrated

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# 日志
*.log

# 临时文件
tmp.*.json
katex_in_*.json
katex_out_*.json

# OCR 临时文件
*_ocr_tmp.txt

# Qdrant 哨兵文件
NUL

# 守望文件夹运行时状态
data/file_state.jsonl

# 守望文件夹（v2）— 摄入文件不提交，仅保留 .gitkeep
data/inbox/*
!data/inbox/.gitkeep
data/watch_processed/*
!data/watch_processed/.gitkeep
data/watch_dead_letter/*
!data/watch_dead_letter/.gitkeep

# WorkBuddy 内部目录
.workbuddy/
