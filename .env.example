# ═══════════════════════════════════════════════════════
# Citrinitas · 熔知 / MindForge
# 环境配置文件模板
# 
# 使用方式：复制此文件为 .env，填入你的配置
#   copy .env.example .env
#   notepad .env
# ═══════════════════════════════════════════════════════

# ── LLM 配置（必填）──
# DeepSeek / OpenAI 兼容 API
KB_LLM_API_KEY=sk-your-api-key-here
KB_LLM_BASE_URL=https://api.deepseek.com/v1
KB_LLM_MODEL=deepseek-chat

# ── Qdrant 向量数据库 ──
# 默认本地运行，端口 6333
KB_QDRANT_URL=http://127.0.0.1:6333

# （可选）手动指定 Qdrant 二进制文件路径
# 如果不想用自动检测，或者 Qdrant 装在非标准位置，可手动指定
# QDRANT_PATH=D:\qdrant\qdrant.exe

# ── 嵌入模型（Ollama）──
# 用于文本转向量。在 Ollama 中预先 pull 模型：
#   ollama pull qwen3-embedding:4b
KB_EMBED_MODEL=qwen3-embedding:4b

# ── 置信度阈值 ──
# LOW 以下 → 死信队列 | LOW~HIGH → 待审核 | HIGH 以上 → 直接入库
# 范围 0.0 - 1.0
KB_CONFIDENCE_LOW=0.40
KB_CONFIDENCE_HIGH=0.75

# ── 重排序（可选）──
# 启用后可提升搜索结果精准度，但会增加延迟
KB_RERANK_ENABLED=true
KB_RERANK_MODEL=qwen3-embedding:4b
KB_RERANK_TOP_N=20

# ── 数据根路径（可选）──
# 知识库文件的存储根目录，默认项目目录下的 local_data/
# KB_ROOT_PATH=D:\citrinitas\local_data

# ── OCR 配置（可选）──
# Tesseract OCR 路径（如果使用 Tesseract 作为 OCR 引擎）
# KB_TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# KB_TESSDATA_PREFIX=C:\Program Files\Tesseract-OCR\tessdata

# ── KaTeX 数学公式渲染（可选）──
# 需要 Node.js 环境
# KB_NODE_BIN=node
# KB_NPM_ROOT=./node_modules

# ── 远程 Embedding API（可选）──
# 如果不想用本地 Ollama 生成向量
# KB_EMBED_API_KEY=sk-your-embedding-api-key
# KB_EMBED_BASE_URL=https://api.openai.com/v1
# KB_EMBED_MODEL_NAME=text-embedding-3-small
